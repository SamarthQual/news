# ------------------------------------------------------------------
# Server
# ------------------------------------------------------------------
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:4200

# ------------------------------------------------------------------
# MongoDB
# ------------------------------------------------------------------
MONGO_URI=mongodb://localhost:27017/news_risk

# ------------------------------------------------------------------
# Your company (used by Claude to assess impact relevance)
# ------------------------------------------------------------------
COMPANY_NAME=India Mortgage Guarantee Corporation
COMPANY_INDUSTRY=Banking & Finance / Mortgage Guarantee
COMPANY_CONTEXT=India's first and only mortgage guarantee company, providing credit enhancement on housing loans. Sensitive to housing market trends, RBI/NHB regulations, real estate sector health, interest rate cycles, bank/HFC counterparty exposure.

# ------------------------------------------------------------------
# NewsAPI.org - https://newsapi.org/register
# ------------------------------------------------------------------
NEWSAPI_KEY=replace_with_your_newsapi_key
NEWSAPI_PAGE_SIZE=20
NEWSAPI_LANGUAGE=en

# ------------------------------------------------------------------
# Anthropic - https://console.anthropic.com
# ------------------------------------------------------------------
ANTHROPIC_API_KEY=replace_with_your_anthropic_key
# Options: claude-sonnet-4-6 (default, balanced), claude-haiku-4-5-20251001 (cheap, fast), claude-opus-4-7 (most capable)
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=1024
# How many recent user-corrected articles to include as few-shot calibration examples (0 disables learning)
FEW_SHOT_LIMIT=5

# ------------------------------------------------------------------
# SMTP (Nodemailer)
# Gmail: use an "App Password" - https://myaccount.google.com/apppasswords
# Outlook/Office 365: use smtp.office365.com:587
# ------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=alerts@yourcompany.com
SMTP_PASS=replace_with_app_password
EMAIL_FROM_NAME=News Risk Monitor
EMAIL_FROM=alerts@yourcompany.com

# ------------------------------------------------------------------
# Scheduling (cron expressions, server time)
# ------------------------------------------------------------------
# Every 2 hours by default
FETCH_CRON=0 */2 * * *
# 8:30 AM daily by default
DIGEST_CRON=30 8 * * *
CRON_TIMEZONE=Asia/Kolkata

# Trigger immediate email for items at or above this impact level
ALERT_THRESHOLD=High
